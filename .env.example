# =============================================================================
# Strategy Platform — Environment Variables (Example)
# =============================================================================
# Copy to .env and fill in real values. Never commit .env.
# Treat all keys as enterprise / no-train tier per principle P5.
# =============================================================================


# -----------------------------------------------------------------------------
# Tenancy
# -----------------------------------------------------------------------------
# Hard-coded for single-tenant phase. Replace with real tenant id system later.
TENANT_ID=gp1


# -----------------------------------------------------------------------------
# LLM Providers — router routes per task type (C3)
# At least one of these must be set. Recommend all three for model-diversity
# red-teaming (Phase 3).
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Optional: alternative / fallback providers
QWEN_API_KEY=
DEEPSEEK_API_KEY=

# Default router config file (relative to backend root)
LLM_ROUTER_CONFIG=ai/models.yaml


# -----------------------------------------------------------------------------
# Voice (Phase 4)
# -----------------------------------------------------------------------------
# OpenAI Realtime (default for WebRTC voice copilot)
OPENAI_REALTIME_MODEL=gpt-realtime

# Long-form transcription (Phase 1)
ASSEMBLYAI_API_KEY=
DEEPGRAM_API_KEY=

# TTS for war-game playback and briefings (Phase 3 / Phase 7)
ELEVENLABS_API_KEY=


# -----------------------------------------------------------------------------
# Memory & Embeddings
# -----------------------------------------------------------------------------
# Zep Cloud — temporal facts from conversations
ZEP_API_KEY=
ZEP_BASE_URL=https://api.getzep.com

# Embeddings — at least one required
VOYAGE_API_KEY=
COHERE_API_KEY=
# OpenAI embeddings use OPENAI_API_KEY above

# Multilingual embedding for dedup pass (A4 / T3)
# Options: bge-m3 (self-hosted via vLLM) or multilingual-e5
MULTILINGUAL_EMBED_PROVIDER=
MULTILINGUAL_EMBED_MODEL=


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Postgres — primary store. Must have pgvector extension. Apache AGE optional.
DATABASE_URL=postgresql://strategy:CHANGEME@localhost:5432/strategy_platform
PGVECTOR_ENABLED=true
APACHE_AGE_ENABLED=false


# -----------------------------------------------------------------------------
# Tools / Connectors (Phase 1+)
# -----------------------------------------------------------------------------
# Web search
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=

# Public data
FRED_API_KEY=
NEWSAPI_KEY=
SEC_EDGAR_USER_AGENT="Strategy Platform contact@example.com"

# Execution tool connectors (Phase 5) — per-portco, store in tenant config
LINEAR_API_KEY=
NOTION_INTEGRATION_TOKEN=
JIRA_API_TOKEN=
SLACK_BOT_TOKEN=
STRIPE_API_KEY=
GA4_CREDENTIALS_PATH=


# -----------------------------------------------------------------------------
# Code interpreter sandbox (Phase 2, OD11)
# -----------------------------------------------------------------------------
E2B_API_KEY=
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=


# -----------------------------------------------------------------------------
# Auth (OD3)
# -----------------------------------------------------------------------------
OIDC_PROVIDER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3000/auth/callback
JWT_SECRET=CHANGEME


# -----------------------------------------------------------------------------
# Cost & Observability (P8)
# -----------------------------------------------------------------------------
COST_SOFT_CAP_USD_PER_USER_PER_DAY=10
COST_HARD_CAP_USD_PER_USER_PER_DAY=25
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=strategy-platform


# -----------------------------------------------------------------------------
# Deployment
# -----------------------------------------------------------------------------
APP_ENV=development
APP_BASE_URL=http://localhost:3000
BACKEND_BASE_URL=http://localhost:5001


# -----------------------------------------------------------------------------
# Manus-specific (if applicable)
# -----------------------------------------------------------------------------
# Add Manus deployment / build variables here when configured
